# ── Banco de dados (Railway PostgreSQL) ───────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/edu_quadros_erp?schema=public"

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria"
JWT_EXPIRES_IN="30d"

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── URL do frontend (para CORS) ───────────────────────────────────────────────
FRONTEND_URL="https://seu-app.vercel.app"

# ── NF-e (Focus NFe) — opcional ───────────────────────────────────────────────
FOCUS_NFE_TOKEN=""
FOCUS_NFE_BASE_URL="https://homologacao.focusnfe.com.br"

# ── Storage (Cloudflare R2) — opcional ───────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="edu-quadros-erp"
